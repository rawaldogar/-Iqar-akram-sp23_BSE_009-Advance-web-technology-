<!DOCTYPE html>
<html>
<head>
    <title>Edit Event - UniEvents</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body { background-color: #0f172a; color: white; height: 100vh; display: flex; align-items: center; }
        .card { background-color: #1e293b; border: none; border-radius: 20px; padding: 40px; box-shadow: 0 15px 35px rgba(0,0,0,0.5); width: 100%; max-width: 550px; margin: auto; }
        .form-control { background: #0f172a; border: 1px solid #334155; color: white; border-radius: 10px; padding: 12px; margin-bottom: 20px; }
        .btn-update { background-color: #06b6d4; border: none; color: white; font-weight: bold; padding: 12px; border-radius: 10px; width: 100%; }
        label { color: #94a3b8; font-size: 0.8rem; font-weight: bold; margin-bottom: 8px; display: block; }
    </style>
</head>
<body>
    <div class="container">
        <div class="card">
            <h2 class="fw-bold mb-4">Edit Event Details</h2>
            <form action="/edit/<%= event._id %>" method="POST">
                <label>EVENT TITLE</label>
                <input type="text" name="title" class="form-control" value="<%= event.title %>" required>
                
                <div class="row">
                    <div class="col-md-6">
                        <label>DATE</label>
                        <input type="date" name="date" class="form-control" value="<%= event.date %>" required>
                    </div>
                    <div class="col-md-6">
                        <label>LOCATION</label>
                        <input type="text" name="location" class="form-control" value="<%= event.location %>" required>
                    </div>
                </div>
                
                <label>DESCRIPTION</label>
                <textarea name="description" class="form-control" rows="3"><%= event.description %></textarea>
                
                <button type="submit" class="btn btn-update shadow">UPDATE EVENT</button>
                <a href="/" class="d-block text-center mt-3 text-muted text-decoration-none small">Cancel</a>
            </form>
        </div>
    </div>
</body>
</html>