<!DOCTYPE html>
<html>
<head>
    <title>Add Event - UniEvents</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body { background-color: #0f172a; color: white; height: 100vh; display: flex; align-items: center; }
        .form-card { background-color: #1e293b; border-radius: 15px; padding: 40px; max-width: 500px; margin: auto; box-shadow: 0 10px 30px rgba(0,0,0,0.5); border-top: 5px solid #06b6d4; }
        .form-control { background: #0f172a; border: 1px solid #334155; color: white; margin-bottom: 20px; padding: 12px; }
        .form-control:focus { background: #0f172a; color: white; border-color: #06b6d4; box-shadow: none; }
        .btn-teal { background-color: #06b6d4; border: none; color: white; padding: 12px; font-weight: bold; width: 100%; border-radius: 8px; }
        label { color: #94a3b8; font-size: 0.8rem; font-weight: bold; margin-bottom: 5px; }
    </style>
</head>
<body>
    <div class="container">
        <div class="form-card">
            <h2 class="fw-bold mb-4">Create New Event</h2>
            <form action="/add" method="POST">
                <label>EVENT TITLE</label>
                <input type="text" name="title" class="form-control" placeholder="e.g. Science Fair" required>
                
                <label>DATE</label>
                <input type="date" name="date" class="form-control" required>
                
                <label>LOCATION</label>
                <input type="text" name="location" class="form-control" placeholder="Auditorium A" required>
                
                <label>DESCRIPTION</label>
                <textarea name="description" class="form-control" rows="3"></textarea>
                
                <button type="submit" class="btn btn-teal">SAVE EVENT</button>
                <a href="/" class="d-block text-center mt-3 text-muted text-decoration-none">Cancel</a>
            </form>
        </div>
    </div>
</body>
</html>