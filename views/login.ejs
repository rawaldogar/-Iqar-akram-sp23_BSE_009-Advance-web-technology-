<!DOCTYPE html>
<html>
<head>
    <title>Login - UniEvents</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body { background-color: #0f172a; color: white; font-family: sans-serif; height: 100vh; display: flex; align-items: center; }
        .login-card { background-color: #1e293b; border-radius: 15px; overflow: hidden; max-width: 850px; margin: auto; display: flex; box-shadow: 0 10px 30px rgba(0,0,0,0.5); }
        .form-side { padding: 60px; flex: 1.2; }
        .info-side { background-color: #083344; padding: 60px; flex: 1; text-align: center; display: flex; flex-direction: column; justify-content: center; }
        .btn-teal { background-color: #06b6d4; border: none; color: white; padding: 12px; font-weight: bold; width: 100%; border-radius: 8px; margin-top: 10px; }
        .form-control { background: transparent; border: none; border-bottom: 2px solid #475569; color: white; border-radius: 0; margin-bottom: 25px; padding: 10px 5px; }
        .form-control:focus { background: transparent; color: white; border-color: #06b6d4; box-shadow: none; }
        .error-box { background: rgba(248, 113, 113, 0.2); border: 1px solid #f87171; color: #f87171; border-radius: 8px; padding: 10px; margin-bottom: 20px; font-size: 0.9rem; }
        a { color: #06b6d4; text-decoration: none; }
    </style>
</head>
<body>
    <div class="container">
        <div class="login-card">
            <div class="form-side">
                <h2 class="fw-bold mb-1">Welcome Back</h2>
                <p class="text-muted mb-4">Please sign in to your account.</p>

                <% if (error) { %>
                    <div class="error-box text-center">⚠️ <%= error %></div>
                <% } %>

                <form action="/login" method="POST">
                    <label class="small text-muted fw-bold">EMAIL ADDRESS</label>
                    <input type="email" name="email" class="form-control" placeholder="iqra@example.com" required>
                    
                    <label class="small text-muted fw-bold">PASSWORD</label>
                    <input type="password" name="password" class="form-control" placeholder="••••••••" required>
                    
                    <button type="submit" class="btn btn-teal">SIGN IN</button>
                </form>
                <p class="mt-4 small text-center">New user? <a href="/register">Create an account</a></p>
            </div>
            <div class="info-side">
                <h1 class="fw-bold">Uni Events</h1>
                <p>Manage your university activities in one professional dashboard.</p>
            </div>
        </div>
    </div>
</body>
</html>